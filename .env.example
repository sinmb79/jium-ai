AI_MODE=off
AI_PROVIDER=rule

# Optional server-side paid AI providers.
# Leave blank in secure environments unless the operator explicitly enables them.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLOVA_API_KEY=
CLOVA_BASE_URL=
CLOVA_MODEL=
UPSTAGE_API_KEY=
UPSTAGE_MODEL=solar-pro2
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Optional future server opt-in storage.
DATABASE_URL="postgresql://jium_user:change_me@localhost:5432/jiumai"

# Optional future institution-account server session signing.
# Must be generated as a server-only high-entropy secret, 32+ bytes minimum.
INSTITUTION_SESSION_SECRET=
INSTITUTION_SESSION_KEY_ID=
INSTITUTION_SESSION_SECRET_VALID_FROM=
INSTITUTION_SESSION_SECRET_VALID_UNTIL=

# Optional future institution-account server route configuration.
# Set only on server/desktop runtimes, never with NEXT_PUBLIC_*.
INSTITUTION_ALLOWED_ORIGINS=
INSTITUTION_SECURE_COOKIES=true
INSTITUTION_AUDIT_LEDGER_DIR=
INSTITUTION_AUDIT_LEDGER_FILE=institution-auth-audit-ledger.jsonl
INSTITUTION_ACCOUNT_REGISTRY_DIR=

# Optional desktop release configuration.
# Keep raw values out of public readiness reports.
JIUM_DESKTOP_RELEASE_CHANNEL=
JIUM_DESKTOP_UPDATE_URL=
WINDOWS_SIGNING_CERT_SHA256=
WINDOWS_SIGNING_CERT_PATH=
APPLE_TEAM_ID=
APPLE_SIGNING_IDENTITY=
LINUX_PACKAGE_SIGNING_KEY_ID=
